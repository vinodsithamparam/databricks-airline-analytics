{
  "datasets": [
    {
      "name": "6cb84aa9",
      "displayName": "Top Fifteen Airports Flight Delay And Performance Metrics",
      "queryLines": [
        "SELECT \r\n",
        "    Total_Scheduled_Flights,\r\n",
        "    Avg_Departure_Delay_Min,\r\n",
        "    Avg_Arrival_Delay_Min,\r\n",
        "    On_Time_Performance_Pct,\r\n",
        "    Completion_Factor_Pct\r\n",
        "FROM airline.bts_data.gold_airport_perf\r\n",
        "ORDER BY Total_Scheduled_Flights DESC\r\n",
        "LIMIT 15"
      ]
    },
    {
      "name": "3f1f1695",
      "displayName": "Carrier Performance and Root Cause Analysis",
      "queryLines": [
        "SELECT \r\n",
        "    Reporting_Airline,\r\n",
        "    COUNT(*) AS Total_Flights,\r\n",
        "    SUM(Is_Delayed) AS Total_Delayed_Flights,\r\n",
        "    ROUND((SUM(Is_Delayed) / COUNT(*)) * 100, 2) AS Delay_Rate_Pct,\r\n",
        "    ROUND(AVG(DepDelayMinutes), 2) AS Avg_Departure_Delay_Min,\r\n",
        "    ROUND(AVG(CarrierDelay), 2) AS Avg_Carrier_Delay_Min,\r\n",
        "    ROUND(AVG(WeatherDelay), 2) AS Avg_Weather_Delay_Min,\r\n",
        "    ROUND(AVG(NASDelay), 2) AS Avg_NAS_Delay_Min,\r\n",
        "    ROUND(AVG(SecurityDelay), 2) AS Avg_Security_Delay_Min,\r\n",
        "    ROUND(AVG(LateAircraftDelay), 2) AS Avg_Late_Aircraft_Delay_Min\r\n",
        "FROM airline.bts_data.gold_flight_ops\r\n",
        "GROUP BY Reporting_Airline\r\n",
        "ORDER BY Delay_Rate_Pct DESC;"
      ]
    },
    {
      "name": "5e12631e",
      "displayName": "Route Bottleneck & Network Constraint Identification",
      "queryLines": [
        "SELECT \r\n",
        "    CONCAT(Origin, ' → ', Dest) AS Route,  -- Combined route label\r\n",
        "    Origin,\r\n",
        "    Dest,\r\n",
        "    SUM(Total_Scheduled_Flights) AS Total_Scheduled_Flights,\r\n",
        "    SUM(Total_Delayed_Flights) AS Total_Delayed_Flights,\r\n",
        "    ROUND((SUM(Total_Delayed_Flights) / SUM(Total_Scheduled_Flights)) * 100, 2) AS Agg_Delay_Rate_Pct,\r\n",
        "    ROUND(AVG(Avg_Arrival_Delay_Min), 2) AS Global_Avg_Arrival_Delay_Min\r\n",
        "FROM airline.bts_data.gold_airport_perf\r\n",
        "GROUP BY Origin, Dest\r\n",
        "HAVING Total_Scheduled_Flights >= 1000 -- Filters out low-volume outlier routes\r\n",
        "ORDER BY Agg_Delay_Rate_Pct DESC\r\n",
        "LIMIT 10;"
      ]
    },
    {
      "name": "43bb0464",
      "displayName": "Weekly Congestion & Ground Efficiency Trends",
      "queryLines": [
        "SELECT \r\n",
        "    CASE DayOfWeek\r\n",
        "        WHEN 1 THEN 'Sun'\r\n",
        "        WHEN 2 THEN 'Mon'\r\n",
        "        WHEN 3 THEN 'Tue'\r\n",
        "        WHEN 4 THEN 'Wed'\r\n",
        "        WHEN 5 THEN 'Thu'\r\n",
        "        WHEN 6 THEN 'Fri'\r\n",
        "        WHEN 7 THEN 'Sat'\r\n",
        "    END AS Day_Name,\r\n",
        "    ROUND(AVG(Avg_TaxiOut_Min), 2) AS Mean_TaxiOut_Min,\r\n",
        "    ROUND(AVG(Avg_TaxiIn_Min), 2) AS Mean_TaxiIn_Min,\r\n",
        "    ROUND(AVG(Avg_Departure_Delay_Min), 2) AS Mean_Departure_Delay_Min\r\n",
        "FROM airline.bts_data.gold_airport_perf\r\n",
        "GROUP BY DayOfWeek\r\n",
        "ORDER BY DayOfWeek;"
      ]
    },
    {
      "name": "2c45576e",
      "displayName": "Seasonality & Extreme Disruption Trends",
      "queryLines": [
        "SELECT \r\n",
        "    Year,\r\n",
        "    Month,\r\n",
        "    CONCAT(Year, '-', LPAD(CAST(Month AS STRING), 2, '0')) AS Year_Month,\r\n",
        "    SUM(Total_Scheduled_Flights) AS Monthly_Scheduled,\r\n",
        "    SUM(Total_Cancelled_Flights) AS Monthly_Cancelled,\r\n",
        "    SUM(Total_Diverted_Flights) AS Monthly_Diverted,\r\n",
        "    ROUND(AVG(Completion_Factor_Pct), 2) AS Avg_Completion_Factor_Pct\r\n",
        "FROM airline.bts_data.gold_airport_perf\r\n",
        "GROUP BY Year, Month\r\n",
        "ORDER BY Year, Month;"
      ]
    }
  ],
